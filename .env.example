NERIMITY_BOT_TOKEN=your_bot_token_here

# Your Nerimity user ID — only this user can run /debug and /undebug
OWNER_USER_ID=your_user_id_here

# There is a reminder thing that I couldnt be bothered to remove

# Channel where the bot will post the daily "go play your Wordle" reminder.
# You can get this by right-clicking a channel in Nerimity and copying its ID.
REMINDER_CHANNEL_ID=your_channel_id_here

# Cron expression for reminder time (default: 07:00 Asia/Dubai ~= 03:00 UTC)
# Format: min hour dayOfMonth month dayOfWeek
# Examples:
#   0 3 * * *   -> 03:00 UTC every day (≈ 07:00 Asia/Dubai)
#   0 18 * * *  -> 18:00 UTC every day
REMINDER_CRON=0 3 * * *

